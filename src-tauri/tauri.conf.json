{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Model Hub",
  "version": "0.0.5",
  "identifier": "com.modelhub.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Model Hub",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNjNDMzA4NzE4MjAwMEIKUldRTEFJSnhDTU5qZ2JXdDZmSGd2Q1MxQkdlZDl3NG9kOEVqQUJKcUZRU1ZGMXdkQmFlcmtTUG0K",
      "endpoints": [
        "https://github.com/Happier-X/model-hub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
