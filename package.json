{
  "name": "model-hub",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "node --experimental-strip-types --test src/utils/*.test.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:windows": "tauri build --bundles nsis -c src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@lucide/vue": "^1.26.0",
    "@tanstack/vue-form": "^1.33.2",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "happier-ui": "0.0.1",
    "vue": "3.5.18",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@tailwindcss/vite": "4.1.13",
    "@tauri-apps/cli": "2.11.3",
    "@vitejs/plugin-vue": "6.0.1",
    "eslint": "9.35.0",
    "eslint-plugin-vue": "10.4.0",
    "globals": "16.3.0",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2",
    "typescript-eslint": "8.43.0",
    "vite": "7.1.5",
    "vue-eslint-parser": "10.2.0",
    "vue-tsc": "3.0.5"
  }
}
