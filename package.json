{
  "name": "model-hub",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare:octopus": "powershell -ExecutionPolicy Bypass -File scripts/prepare-bundled-octopus.ps1",
    "prepare:gateway-rust": "powershell -ExecutionPolicy Bypass -File scripts/prepare-bundled-gateway-rust.ps1",
    "release:windows": "pnpm prepare:gateway-rust && tauri build --bundles nsis -c src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@tailwindcss/vite": "4.1.13",
    "@tauri-apps/cli": "2.11.3",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "eslint": "9.35.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2",
    "typescript-eslint": "8.43.0",
    "vite": "7.1.5"
  }
}
